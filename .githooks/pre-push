#!/bin/sh
set -eu

echo "[pre-push] Checking canonical docs drift..."
pnpm -s docs:check

echo "[pre-push] Checking docs truth..."
pnpm -s docs:truth

echo "[pre-push] Checking docs structure..."
pnpm -s docs:structure

echo "[pre-push] Checking code docs up to date..."
pnpm -s docs:codegen:check

echo "[pre-push] Guard sandbox-only manifests..."
pnpm -s guard:sandbox-only

echo "[pre-push] Running lint..."
pnpm -s lint

echo "[pre-push] Running typecheck..."
pnpm -s typecheck

echo "[pre-push] Running full test suite..."
pnpm -s test

echo "[pre-push] Running build..."
pnpm -s build